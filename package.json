{
  "name": "@avoidstarch/ts-kit",
  "version": "0.1.0",
  "description": "Personal kit of shared TypeScript types and functions.",
  "type": "module",
  "license": "MIT",
  "author": "Louis Casinelli",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aVOIDSTARch/ts-kit.git"
  },
  "keywords": ["typescript", "types", "utilities", "kit"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "prettier": "^3",
    "@biomejs/js-api": "^6",
    "@biomejs/wasm-nodejs": "^2"
  },
  "peerDependenciesMeta": {
    "prettier": { "optional": true },
    "@biomejs/js-api": { "optional": true },
    "@biomejs/wasm-nodejs": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3",
    "@types/node": "^22",
    "prettier": "^3",
    "@biomejs/js-api": "^6",
    "@biomejs/wasm-nodejs": "^2"
  }
}
